PORT=5000
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/lostandfound
JWT_SECRET=your-long-random-secret

# Promote an existing user to admin on server start (lowercase email)
# ADMIN_EMAIL=admin@university.edu

# Public stats headline suffix (optional)
# STATS_SEMESTER_LABEL=this semester

# ── Gmail App Password Setup ────────────────────────────────────────
# If these are set, real OTP emails will be sent.
# If omitted, the OTP is still generated and returned in the API
# response (for development), and the frontend will display it.
#
# How to get a Gmail App Password:
#   1. Enable 2FA at https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate a new App Password (16 characters, no spaces)
#   4. Copy it below — do NOT use your regular Gmail password
#   5. If you get "Invalid login" error after setting these,
#      regenerate the App Password and update this file.
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_USER=you@gmail.com
# EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_PASS=xxxx xxxx xxxx xxxx  # fallback variable name; use EMAIL_APP_PASSWORD when possible
